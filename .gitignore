# ===========================================
# 博金游戏平台客户端 .gitignore 配置文件
# ===========================================

# ----------------
# 日志文件
# ----------------
*.log
*.txt
!README.txt
DownLoadLog.txt
GPManagerLog.txt
UpdataCheckLog.txt
dev.log
server.log

# ----------------
# 临时文件
# ----------------
*.tmp
*.temp
*.bak
*.cache
unins000.dat
unins000.exe

# ----------------
# 系统文件
# ----------------
# Windows
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
*.stackdump

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux
*~
.fuse_hidden*
.directory
.Trash-*

# ----------------
# 用户数据文件
# ----------------
# 用户配置和数据（包含敏感信息）
ServerInfo.INI
user_data/
save/
screenshot/

# ----------------
# 开发环境
# ----------------
# IDE 和编辑器
.idea/
.vscode/
*.swp
*.swo
*.sublime-*

# 编译产物
*.obj
*.pdb
*.ilk
*.exp
*.lib
*.res
*.tlog

# 调试文件
*.pdb
*.map

# ----------------
# Node.js / Next.js
# ----------------
node_modules/
.next/
out/
build/
dist/
.npm
.yarn/

# 依赖锁文件（可选）
# bun.lock
# package-lock.json
# yarn.lock

# ----------------
# 环境配置
# ----------------
.env
.env.*
.env.local
.env.*.local
local-*

# ----------------
# 其他
# ----------------
# 测试目录
coverage/
test/
tests/

# 备份目录
backup/
bak/

# 上传目录（临时文件）
upload/

# Claude/AI 配置
.claude/
.z-ai-config/

# TypeScript 编译缓存
*.tsbuildinfo
next-env.d.ts

# Vercel
.vercel/

# 敏感文件
*.pem
*.key
*.p12
*.pfx
